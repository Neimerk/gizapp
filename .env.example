# BrasUX Shopping — exemplo de variáveis de ambiente (sem segredos)
# Copie para .env e preencha. Em produção (Vercel), defina no painel.

# Supabase (projeto único)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ... (anon key pública)

# Cliente "shopping" — MESMO projeto, MESMA anon key
VITE_SHOPPING_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SHOPPING_SUPABASE_ANON_KEY=eyJ... (anon key pública)

# Imagens (Supabase Storage)
VITE_IMAGE_BASE_URL=https://SEU-PROJETO.supabase.co/storage/v1/object/public

# API .NET (ImageAPI + SignalR). O código lê VITE_API_URL.
# Em produção aponte AMBAS para o host deployado (Railway/Render), nunca localhost.
VITE_API_URL=https://api.seu-dominio.com.br
VITE_IMAGE_API_URL=https://api.seu-dominio.com.br

# MapBox (rastreamento) — opcional
VITE_MAPBOX_TOKEN=

# Web Push (VAPID) — chave PÚBLICA
VITE_VAPID_PUBLIC_KEY=

# PIX estático — opcional
VITE_PIX_KEY=
VITE_PIX_MERCHANT_NAME=BrasUX
VITE_PIX_MERCHANT_CITY=Brasil
